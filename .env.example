# Signer Mode (direct | superrise)
# - direct: uses CKB_ESCROW_PRIVATE_KEY from .env (TESTNET ONLY)
# - superrise: delegates to SuperRise wallet-server (testnet + mainnet safe)
SIGNER_MODE=direct

# Option A: Direct Private Key (testnet only, for quick testing)
CKB_ESCROW_PRIVATE_KEY=your_private_key_here

# Option B: SuperRise Wallet Server (testnet + mainnet safe, key isolated)
# Uncomment and set to use SuperRise instead of direct key
# SIGNER_MODE=superrise
# WALLET_SERVER_URL=http://localhost:3000

